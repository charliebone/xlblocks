{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Excel: Attach",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "preLaunchTask": "launchexcel",
            "targetArchitecture": "x86_64"
        },
        {
            "name": "Excel: Launch xlBrew",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "targetArchitecture": "x86_64",
            "program": "C:\\Program Files\\Microsoft Office\\root\\Office16\\EXCEL.EXE",
            "args": [ "${workspaceFolder}/xlBrew.AddIn/bin/Debug/net6.0-windows/xlBrew64-AddIn.xll" ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": "C#: xlBrew Debug",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/xlBrew/xlBrew.csproj"
        }


    ]
}